# backend/.env — local development settings
# Copied automatically; no secrets here.
# For production, create backend/.env.prod with real values.

# JWT secret — change this even in dev if you share the machine
SECRET_KEY=dev-secret-change-me-in-production

# Cookie is NOT secure in dev (HTTP). Set to true in production (HTTPS).
COOKIE_SECURE=false

# Token lifetime: 7 days
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Paths (defaults work for `cd backend && uvicorn main:app`)
DATA_DIR=data
AUTH_DB_PATH=data/auth.db
USERS_DATA_DIR=data/users

# Ollama (optional AI categorization)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
