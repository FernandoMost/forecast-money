# ─────────────────────────────────────────────────────────────────────────────
# Finance Analyzer — environment configuration
# Copy this file to .env and fill in values as needed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Local mode (default) ─────────────────────────────────────────────────────
# SQLite database path (relative to backend/ working directory)
DB_PATH=data/finance.db
DATA_DIR=data

# ── AI categorization (optional, local) ──────────────────────────────────────
# Ollama must be running locally for AI categorization to work.
# Default model: llama3. Change to llama3.1, mistral, etc. as needed.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Cloud mode (optional — Phase 5) ──────────────────────────────────────────
# Uncomment and set MONGO_URI to switch from SQLite to MongoDB Atlas.
# When set, all data will be persisted to MongoDB instead of SQLite.
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/finance_analyzer
